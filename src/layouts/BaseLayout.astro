---
import Navbar from "../components/layout/Navbar.astro";
import Footer from "../components/layout/Footer.astro";
import "../styles/global.css";

// Define the Props so you can pass a unique description from each page
const {
	title = "Web Dev Final",
	description = "This contains the final webdev final project that buckets all the templates created by the company.",
} = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/avif" href="/images/logo.avif" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />

		<meta name="description" content={description} />

		<!-- Preload critical font with font-display: swap to prevent FOUT -->
		<link
			rel="preload"
			href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap"
			as="style"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap"
			rel="stylesheet"
		/>

		<title>{title}</title>
	</head>
	<body
		class="min-h-screen flex flex-col font-primary"
		style="font-family: 'Poppins', ui-sans-serif, system-ui, sans-serif;"
	>
		<Navbar />
		<main class="flex-1">
			<slot />
		</main>
		<Footer />
	</body>
</html>
