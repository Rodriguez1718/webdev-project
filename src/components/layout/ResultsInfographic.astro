---
// Results Infographic - Compact metrics summary
// Displays key performance indicators in a minimal, non-redundant format
import StatCard from "../ui/StatCard.astro";

const metrics = [
  {
    id: "results-card-1",
    title: "Websites Built",
    target: 2500,
    suffix: "+",
    description: "Websites Built",
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path>',
  },
  {
    id: "results-card-2",
    title: "Lead Increase",
    target: 150,
    suffix: "%",
    description: "Lead Increase",
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>',
  },
  {
    id: "results-card-3",
    title: "Client Rating",
    target: 4.9,
    suffix: "/5",
    description: "Client Rating",
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path>',
  },
];
---

<section
  class="py-12 bg-parchment border-y border-[#E5E7EB] relative overflow-hidden results-infographic"
>
  <div
    class="absolute inset-0 bg-linear-to-r from-[#F48C06]/5 via-transparent to-[#1B4D7E]/5 -z-10"
  >
  </div>

  <div class="container-custom px-8">
    <!-- Header -->
    <div class="text-center mb-10 md:mb-12">
      <span
        id="results-tag"
        class="font-semibold tracking-widest uppercase mb-4 inline-block"
        style="color: var(--helios-orange); font-size: 16px;">PROVEN RESULTS</span
      >
      <h2 id="results-title" class="text-3xl md:text-5xl font-bold text-[#0A1931] leading-tight mb-2">
        Real Impact, <span class="text-[#F48C06]">Real Numbers</span>
      </h2>
      <p
        id="results-desc"
        class="text-[#0A1931] max-w-5xl mx-auto mt-4"
        style="font-size: 22px;"
      >
        Join thousands of contractors transforming their digital presence with
        BuildPro.
      </p>
    </div>

    <!-- Metrics Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {
        metrics.map((metric) => (
          <StatCard
            id={metric.id}
            title={metric.title}
            target={metric.target}
            suffix={metric.suffix}
            description={metric.description}
            icon={metric.icon}
          />
        ))
      }
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    // Counter animation function
    function animateCounter(
      element: HTMLElement,
      target: number,
      suffix: string,
      duration: number,
    ) {
      let start = 0;
      const increment = target / (duration / 16);

      function updateCounter() {
        start += increment;
        if (start < target) {
          const currentValue =
            target % 1 !== 0
              ? start.toFixed(1)
              : Math.floor(start).toLocaleString();
          element.innerHTML =
            currentValue +
            '<span class="text-white text-5xl ml-1 transition-colors duration-400">' +
            suffix +
            "</span>";
          requestAnimationFrame(updateCounter);
        } else {
          const finalValue =
            target % 1 !== 0 ? target.toFixed(1) : target.toLocaleString();
          element.innerHTML =
            finalValue +
            '<span class="text-white text-5xl ml-1 transition-colors duration-400">' +
            suffix +
            "</span>";
        }
      }

      updateCounter();
    }

    // Intersection Observer for counter animation
    const observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            const counters = entry.target.querySelectorAll("[data-target]");

            counters.forEach(function (counter) {
              const targetAttr = counter.getAttribute("data-target");
              const suffixAttr = counter.getAttribute("data-suffix");

              if (targetAttr && !counter.classList.contains("animated")) {
                const target = parseFloat(targetAttr);
                const suffix = suffixAttr || "";

                counter.classList.add("animated");
                animateCounter(counter as HTMLElement, target, suffix, 2000);
              }
            });
          }
        });
      },
      {
        threshold: 0.3,
        rootMargin: "0px 0px -50px 0px",
      },
    );

    // Observe the results section specifically
    const resultsSection = document.querySelector(".results-infographic");
    if (resultsSection) {
      observer.observe(resultsSection);
    }
  });
</script>
