---
// CoreSteps Section Component - Shows the workflow/process in a visual timeline
// Styled to match the project's dark navy & orange aesthetic
import Button from "../ui/Button.astro";

export interface Props {
  title?: string;
  highlightWord?: string;
  description?: string;
  steps?: Array<{
    number: number;
    title: string;
    description: string;
    icon?: string;
  }>;
}

const {
  title = "How It Works",
  highlightWord = "Works",
  description = "Our proven process gets your business online and generating leads in no time.",
  steps = [
    {
      number: 1,
      title: "Discovery & Planning",
      description: "We learn about your business, goals, and target audience to create a tailored strategy.",
    },
    {
      number: 2,
      title: "Design & Development",
      description: "Our team builds a stunning, conversion-focused website optimized for your industry.",
    },
    {
      number: 3,
      title: "Launch & Optimization",
      description: "We deploy your site and implement SEO, analytics, and performance tracking.",
    },
    {
      number: 4,
      title: "Growth & Support",
      description: "Ongoing support and optimization to ensure your site continues to generate leads.",
    },
  ],
} = Astro.props;

const titleParts = title.split(highlightWord);
---

<section class="relative py-20 md:py-32 overflow-hidden bg-parchment">
  <!-- Subtle dot grid overlay -->
  <div
    class="absolute inset-0 opacity-40"
    style="background-image: radial-gradient(circle, rgba(10,25,49,0.06) 1px, transparent 1px); background-size: 28px 28px;"
  ></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 coresteps-header">
      <span
        class="font-semibold tracking-widest uppercase mb-3 inline-block"
        style="color: var(--helios-orange); font-size: 16px;"
      >
        OUR PROCESS
      </span>
      <h2 class="text-3xl md:text-5xl font-bold mb-6 mt-4 leading-tight" style="color: var(--midnight-navy);">
        {titleParts[0]}
        <span style="color: var(--helios-orange);">{highlightWord}</span>
        {titleParts[1]}
      </h2>
      <p class="max-w-3xl mx-auto leading-relaxed" style="font-size: 22px; color: var(--machinist);">
        {description}
      </p>
    </div>

    <!-- Steps Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 coresteps-grid">
      {steps.map((step, index) => (
        <div class="corestep-card group relative" style={`--delay: ${index * 0.15}s`}>
          <!-- Connector line (desktop only) -->
          {index < steps.length - 1 && (
            <div class="hidden lg:block absolute top-10 left-full w-6 h-px z-20 pointer-events-none"
              style="background: linear-gradient(90deg, rgba(244,140,6,0.5), transparent);">
            </div>
          )}

          <!-- Glassy Card -->
          <div class="h-full flex flex-col p-8 rounded-3xl bg-white border border-[#99B0BB]/40 hover:border-[#F48C06]/60 transition-all duration-500 hover:shadow-xl hover:shadow-[#F48C06]/10 hover:-translate-y-1">

            <!-- Step Number Badge -->
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-[#F48C06] to-[#E67E22] flex items-center justify-center shadow-lg mb-6 group-hover:scale-110 transition-transform duration-300 flex-shrink-0">
              <span class="text-xl font-bold text-white">
                {String(step.number).padStart(2, '0')}
              </span>
            </div>

            <!-- Content -->
            <div class="flex-1">
              <h3 class="text-lg font-bold mb-3 group-hover:text-[#F48C06] transition-colors duration-300" style="color: var(--midnight-navy);">
                {step.title}
              </h3>
              <p class="leading-relaxed text-sm" style="color: var(--machinist);">
                {step.description}
              </p>
            </div>

            <!-- Bottom accent line -->
            <div class="mt-6 h-0.5 w-0 bg-gradient-to-r from-[#F48C06] to-[#E67E22] rounded-full transition-all duration-500 group-hover:w-full"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-16 coresteps-cta">
      <p class="mb-6" style="color: var(--machinist);">Ready to get started with your digital transformation?</p>
      <Button href="/contact" variant="primary" size="md" ariaLabel="Start your project with BuildPro">
        Start Your Project
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </Button>
    </div>
  </div>
</section>

<style>
  /* Initial hidden state for scroll animations */
  .coresteps-header,
  .coresteps-cta {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .coresteps-header { transition-delay: 0.1s; }
  .coresteps-cta    { transition-delay: 0.5s; }

  .corestep-card {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    transition-delay: var(--delay, 0s);
  }

  /* Animate-in state */
  .animate-in .coresteps-header,
  .animate-in .corestep-card,
  .animate-in .coresteps-cta,
  .coresteps-header.animate-in,
  .corestep-card.animate-in,
  .coresteps-cta.animate-in {
    opacity: 1;
    transform: translateY(0);
  }

  /* Subtle shimmer on number badges */
  @keyframes badge-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(244, 140, 6, 0.3); }
    50%       { box-shadow: 0 0 0 8px rgba(244, 140, 6, 0); }
  }

  .corestep-card:hover .w-14 {
    animation: badge-pulse 2s infinite;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("animate-in");
          }
        });
      },
      { threshold: 0.12, rootMargin: "0px 0px -60px 0px" }
    );

    document.querySelectorAll(".coresteps-header, .corestep-card, .coresteps-cta").forEach((el) => {
      observer.observe(el);
    });
  });
</script>
