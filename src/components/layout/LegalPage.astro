---
interface Props {
    title: string;
    lastUpdated?: string;
    content: string;
    isSitemap?: boolean;
}

const { title, lastUpdated, content, isSitemap = false } = Astro.props;
---

<style is:global>
    .legal-content {
        color: #0a1931;
    }

    .legal-content h2 {
        font-size: 1.875rem;
        font-weight: 700;
        color: #0a1931;
        margin-bottom: 1.5rem;
        margin-top: 3rem;
    }

    .legal-content p {
        font-size: 1rem;
        color: #0a1931;
        margin-bottom: 1.5rem;
        line-height: 1.625;
    }

    .legal-content ul {
        list-style-type: disc;
        list-style-position: inside;
        color: #0a1931;
        margin-bottom: 2rem;
        margin-left: 1rem;
    }

    .legal-content ul li {
        margin-bottom: 0.5rem;
    }

    .legal-content li {
        font-size: 1rem;
        color: #0a1931;
        line-height: 1.625;
    }

    .legal-content a {
        color: #f48c06;
        font-weight: 500;
        transition: color 200ms ease;
    }

    .legal-content a:hover {
        color: #ff6b35;
    }

    .legal-content strong {
        font-weight: 600;
    }

    .legal-content .contact-box {
        background-color: #f3f4f6;
        padding: 1.5rem;
        border-radius: 0.5rem;
        color: #0a1931;
        margin-bottom: 2rem;
    }

    .legal-content .contact-box p {
        margin-bottom: 0.5rem;
    }

    /* Sitemap specific styles */
    .sitemap-content {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
    }

    @media (min-width: 768px) {
        .sitemap-content {
            grid-template-columns: 1fr 1fr;
        }
    }

    .sitemap-content > p:first-child {
        grid-column: 1 / -1;
    }

    .sitemap-content h2 {
        grid-column: 1 / -1;
        margin-top: 0;
    }

    .sitemap-content h2:nth-of-type(2),
    .sitemap-content h2:nth-of-type(3),
    .sitemap-content h2:nth-of-type(4),
    .sitemap-content h2:nth-of-type(5) {
        grid-column: auto;
    }

    /* Sitemap grid layout */
    .sitemap-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
    }

    @media (min-width: 768px) {
        .sitemap-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    .sitemap-column {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .sitemap-column h2 {
        margin-top: 0;
    }
</style>

<!-- Hero Section -->
<section class="py-20 bg-linear-to-br from-[#0a1931] to-[#1a2a4a]">
    <div class="max-w-4xl mx-auto px-8">
        <h1 class="text-5xl font-bold text-white mb-4">{title}</h1>
        {
            lastUpdated && (
                <p class="text-lg text-white/80">Last updated: {lastUpdated}</p>
            )
        }
    </div>
</section>

<!-- Content Section -->
<section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-8">
        {
            isSitemap ? (
                <div class="legal-content sitemap-content" set:html={content} />
            ) : (
                <div class="legal-content" set:html={content} />
            )
        }
    </div>
</section>
