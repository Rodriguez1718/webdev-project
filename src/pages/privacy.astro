---
import BaseLayout from "../layouts/BaseLayout.astro";
import LegalPage from "../components/layout/LegalPage.astro";
import { getCollection } from "astro:content";

const privacyDoc = (await getCollection("legal")).find((doc) =>
    doc.id.includes("privacy"),
);

if (!privacyDoc) {
    throw new Error("Privacy policy document not found");
}

const content = privacyDoc.body || "";
---

<BaseLayout
    title="Privacy Policy | BuildPro"
    description="Learn how BuildPro protects your personal information and privacy. Our comprehensive privacy policy explains data collection, usage, and your rights."
>
    <LegalPage
        title={privacyDoc.data.title}
        lastUpdated={privacyDoc.data.lastUpdated}
        content={content}
    />
</BaseLayout>
