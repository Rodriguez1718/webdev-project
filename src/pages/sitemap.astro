---
import BaseLayout from "../layouts/BaseLayout.astro";
import LegalPage from "../components/layout/LegalPage.astro";
import { getCollection } from "astro:content";

const sitemapDoc = (await getCollection("legal")).find(
    (doc) => doc.id.includes("sitemap"),
);

if (!sitemapDoc) {
    throw new Error("Sitemap document not found");
}

const content = sitemapDoc.body || "";
---

<BaseLayout
    title="Sitemap | BuildPro"
    description="Browse the complete sitemap of BuildPro's website. Find links to all pages and services."
>
    <LegalPage
        title={sitemapDoc.data.title}
        content={content}
    />
</BaseLayout>
