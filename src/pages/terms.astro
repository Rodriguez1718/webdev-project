---
import BaseLayout from "../layouts/BaseLayout.astro";
import LegalPage from "../components/layout/LegalPage.astro";
import { getCollection } from "astro:content";

const termsDoc = (await getCollection("legal")).find((doc) =>
    doc.id.includes("terms"),
);

if (!termsDoc) {
    throw new Error("Terms of service document not found");
}

const content = termsDoc.body || "";
---

<BaseLayout
    title="Terms of Service | BuildPro"
    description="Read BuildPro's Terms of Service. Understand the rules and conditions for using our website and services."
>
    <LegalPage
        title={termsDoc.data.title}
        lastUpdated={termsDoc.data.lastUpdated}
        content={content}
    />
</BaseLayout>
